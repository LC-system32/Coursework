{
  "manifest_version": 3,
  "name": "Data Import Bridge",
  "version": "1.0",
  "description": "Імпортування даних між системою верифікації робіт та StrikePlagiarism через popup-вікно налаштувань.",
  "homepage_url": "https://fotius.cdu.edu.ua/",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Data Import Bridge",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "content/content-constants.js",
        "content/content-toast-service.js",
        "content/content-picker-dom-service.js",
        "content/content-picker-session-service.js",
        "content/content-form-io-service.js",
        "content/content-file-transfer-service.js",
        "content/content-import-flow-service.js",
        "content/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "run-direct-import": {
      "suggested_key": {
        "default": "Ctrl+Shift+F",
        "mac": "Command+Shift+F"
      },
      "description": "Запустити імпорт даних"
    }
  }
}

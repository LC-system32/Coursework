{
  "manifest_version": 3,
  "name": "Data Import Bridge",
  "version": "2.0",
  "description": "Імпортування даних між системою верифікації робіт та StrikePlagiarism через popup-вікно налаштувань.",
  "homepage_url": "https://fotius.cdu.edu.ua/",
  "icons": {
    "32": "favicon.svg"
  },
  "developer": {
    "name": "Alex",
    "url": "https://fotius.cdu.edu.ua/"
  },
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "scripts": [
      "background/background-constants.js",
      "background/background-debug-service.js",
      "background/background-tab-service.js",
      "background/background-picker-session-service.js",
      "background/background-file-service.js",
      "background/background-import-flow-service.js",
      "background/background-picker-message-service.js",
      "background/background-message-router-service.js",
      "background/background-command-service.js",
      "background.js"
    ]
  },
  "action": {
    "default_title": "Data Import Bridge",
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "content/content-constants.js",
        "content/content-toast-service.js",
        "content/content-picker-dom-service.js",
        "content/content-picker-session-service.js",
        "content/content-form-io-service.js",
        "content/content-file-transfer-service.js",
        "content/content-import-flow-service.js",
        "content/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "alehamartinenko0@gmail.com",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "commands": {
    "run-direct-import": {
      "suggested_key": {
        "default": "Ctrl+Shift+F",
        "mac": "Command+Shift+F"
      },
      "description": "Запустити імпорт даних"
    }
  }
}
{
  "manifest_version": 3,
  "name": "Data Import Bridge",
  "version": "1.2.0",
  "description": "Імпортування даних між системою верифікації робіт та StrikePlagiarism через popup-вікно налаштувань.",
  "homepage_url": "https://fotius.cdu.edu.ua/",
  "developer": {
    "name": "Ilya",
    "url": "https://fotius.cdu.edu.ua/"
  },
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "action": {
    "default_title": "Data Import Bridge",
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "content/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "data-import-bridge@vu.cdu.edu.ua",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}